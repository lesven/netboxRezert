# Copy to .env and fill in real values. Never commit the real .env.

# NetBox connection. Use a service-account token scoped to write only the
# vm_product_owner custom field + journal entries (see CLAUDE.md).
NETBOX_URL=https://netbox.internal.example.com
NETBOX_TOKEN=

# true = use the built-in in-memory fixture instead of a real NetBox
NETBOX_MOCK=false

# Where the token->contact mapping is stored inside the container
DATABASE_PATH=/app/data/tokens.sqlite3

# Public base URL this tool is reachable under, used to build links in
# scripts/generate_tokens.py output.
BASE_URL=http://localhost:8080

# SSL-Zertifikatsprüfung für die NetBox-Verbindung.
# Auf false setzen, wenn NetBox ein self-signed/internes CA-Zertifikat verwendet
# und das CA-Bundle im Container nicht verfügbar ist.
# Warnung: Deaktiviert den Schutz vor Man-in-the-Middle-Angriffen.
NETBOX_SSL_VERIFY=true
